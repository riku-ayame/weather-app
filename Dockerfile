# 1. ベースとなるOSとPythonのバージョンを指定（今回は少し軽めのPython 3.9を使います）
FROM python:3.9-slim

# 2. コンテナ（仮想の箱）の中での「作業用フォルダ」を作る
WORKDIR /app

# 3. 私たちのPCにある「設計図（requirements.txt）」を、コンテナの中にコピーする
COPY requirements.txt .

# 4. コンテナの中でライブラリを一括インストールする
RUN pip install --no-cache-dir -r requirements.txt

# 5. アプリのコード（.pyファイルなど）をすべてコンテナの中にコピーする
COPY . .

# 6. Streamlitが使う通信ポート（8501番）を開けておく
EXPOSE 8501

# 7. コンテナが起動した瞬間に、自動で実行するコマンド
CMD ["streamlit", "run", "1Streamlit.py", "--server.port=8501", "--server.address=0.0.0.0"]



##Docker（ドッカー）とは？（超ざっくり）
# 船で荷物を運ぶときの「コンテナ」を想像してください。
# 昔は、荷物の形がバラバラで船に積むのが大変でした。
#しかし「世界共通サイズの鉄の箱（コンテナ）」が発明されたことで、世界中のどの港でも、
#どんな船やトラックでも同じように運べるようになりました。
# Dockerも全く同じです。
# あなたの「Pythonの設定」＋「インストールしたライブラリ」＋「コード」をひとまとめにして
#「コンテナ」という箱に閉じ込めます。
#この箱は、Macでも、Windowsでも、Linuxのサーバーでも、全く同じように動く最強の魔法の箱です。



##使い方
# 1. ターミナル（コマンドプロンプト）を開いて、Dockerがインストールされていることを確認します。
#    コマンド: docker --version
# 2. Dockerfileがあるフォルダに移動します。
#    コマンド: cd /path/to/your/app
# 3. Dockerイメージをビルドします。イメージはコンテナの設計図のようなものです。
#    コマンド: docker build -t my-streamlit-app .
# 4. ビルドしたイメージからコンテナを起動します。これでアプリが動き始めます。
#    コマンド: docker run -p 8501:8501 my-streamlit-app
#    -p 8501:8501: これが「ポートフォワーディング」と呼ばれる魔法です。
#   「Macの8501番のドアを開けたら、コンテナの中の8501番のドア（Streamlitの画面）に繋げてね」という、
#    外の世界と箱の中を繋ぐトンネル工事をしています。
# 5. ブラウザで http://localhost:8501 にアクセスすると、Streamlitアプリが表示されます。